{
  "name": "chinup-booking",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web,sync -c blue,green,magenta \"node --watch mock-server.js\" \"vite\" \"node scripts/auto-pull.js\"",
    "dev:web": "vite",
    "dev:api": "node --watch mock-server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:api": "node tests/test-api.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
